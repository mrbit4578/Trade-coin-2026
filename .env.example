# ══════════════════════════════════════════════════════
# Trade-coin-2026 — copy to .env (NEVER commit .env)
# ══════════════════════════════════════════════════════

MODE=paper
LIVE_CONFIRM=false
PAPER_CAPITAL_USD=1000

# paper | binance | mexc | polymarket
TRADE_VENUE=paper
QUOTE_ASSET=USDT

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# MEXC
MEXC_API_KEY=
MEXC_API_SECRET=

SYMBOLS=BTC,ETH,SOL,BNB,DOGE,NEAR

HALF_KELLY=true
MAX_DAILY_LOSS_PCT=0.02
MAX_CONSECUTIVE_LOSSES=5
EDGE_THRESHOLD=0.05
SPOT_EDGE_THRESHOLD=0.05
MIN_ORDERBOOK_LIQUIDITY_USD=50000
MAX_POSITION_PCT=0.05
ENABLE_SPOT_SELLS=true

MC_SIMULATIONS=10000
MIROFISH_AGENTS=200
MIROFISH_ENABLED=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp: none | callmebot | twilio | meta
WHATSAPP_PROVIDER=none
WHATSAPP_PHONE=
WHATSAPP_CALLMEBOT_APIKEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=
WHATSAPP_META_TOKEN=
WHATSAPP_META_PHONE_ID=
WHATSAPP_META_TO=

# Web — bot + data tự chạy khi mở dashboard
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_API_TOKEN=
AUTO_START_BOT=true
WEB_USE_WEBSOCKETS=true
TRADE_COOLDOWN_SEC=300

# AI optional
AI_PROVIDER=none
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# OTC optional
OTC_FEED_URL=
OTC_FEED_API_KEY=
OTC_SIMULATE=true

# Polymarket optional
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_CHAIN_ID=137
POLYMARKET_SIGNATURE_TYPE=0

SCAN_INTERVAL_SEC=15
LOG_LEVEL=INFO
DATA_DIR=data
